# 排除敏感文件
.env
*.key
*.pem
*.p12

# Exclude Hermes runtime data (root-level only)
.hermes/
.hermes-win/
*.db
/sessions/
/logs/
/cron/
/memories/

# 排除虚拟环境
.venv/
.venv-hermes-win/
venv/
__pycache__/
*.pyc
*.pyo

# 排除 IDE
.vscode/
.idea/
*.swp
*.swo

# 排除编译产物 (PyInstaller)
launcher/Hermes.exe
launcher/build/
launcher/dist/
*.spec.bak

# Exclude CI-bundled portable environments (generated, not source)
python/
git/
.tmp-venv/
requirements-frozen.txt
Thumbs.db
Desktop.ini
.DS_Store
