# =============================================================================
# Hermes Agent — API Key 配置文件
# =============================================================================
# 至少填入一个提供商的 API Key 即可使用。
# 推荐 DeepSeek（性价比最高）或 OpenRouter（200+ 模型可选）。
#
# 获取地址：
#   DeepSeek:    https://platform.deepseek.com/api_keys
#   OpenRouter:  https://openrouter.ai/keys
#   Anthropic:   https://console.anthropic.com
#   OpenAI:      https://platform.openai.com
#   Google:      https://aistudio.google.com
#   Kimi:        https://platform.kimi.ai
#   GLM:         https://z.ai
#   MiniMax:     https://www.minimax.io
# =============================================================================

# DeepSeek（推荐，默认配置使用此 Key）
DEEPSEEK_API_KEY=sk-CHANGE_ME

# OpenRouter（200+ 模型统一入口）
# OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME

# Anthropic（Claude 系列）
# ANTHROPIC_API_KEY=sk-ant-api03-CHANGE_ME

# OpenAI
# OPENAI_API_KEY=sk-CHANGE_ME

# Google Gemini
# GOOGLE_API_KEY=CHANGE_ME

# Kimi / Moonshot
# KIMI_API_KEY=sk-CHANGE_ME

# GLM / ZhipuAI
# GLM_API_KEY=CHANGE_ME

# MiniMax
# MINIMAX_API_KEY=sk-CHANGE_ME

# Tavily（Web 搜索，可选）
# TAVILY_API_KEY=tvly-CHANGE_ME
